generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── STEP 1: Who is using the app ────────────────────────────────────────────

// The athlete. Identified by phone number.
model User {
  id           String           @id @default(uuid())
  name         String
  phone        String           @unique
  email        String?
  createdAt    DateTime         @default(now())
  // Exercise names the user picked to track on their Weekly Progress report
  // (starred on /prs), capped small (see MAX_FAVORITE_EXERCISES in
  // app/api/favorites/route.ts) — a plain string array rather than a join
  // table since there's no per-favorite metadata and the list stays tiny.
  favoriteExercises String[]    @default([])
  planHistory  UserPlan[]
  sessions     WorkoutSession[]
  createdPlans WorkoutPlan[]    @relation("PlanCreator")
  creatorProfile CreatorProfile?
}

// The creator/influencer-facing profile — separate from User since almost
// every account is a regular athlete, not a creator; keeping this here
// avoids bloating User with fields only a small subset ever populate.
// Prototype stage (see CLAUDE.md's creator-monetization backlog): no
// payment/recruiter-attribution fields yet, just what's needed to make a
// creator's public plan page feel like a real profile instead of a bare name.
model CreatorProfile {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String   @unique
  // Legal name — private, kept for future banking/tax/payout use, never shown
  // publicly. User.name is kept in sync as "firstName lastName" since other
  // parts of the app (menu, admin) still just read the plain User.name field.
  firstName     String?
  lastName      String?
  // Public-facing display name (e.g. "CBum") — shown everywhere a creator's
  // name appears publicly (plan page, previews) instead of their legal name.
  // Falls back to firstName, then to User.name, if not set.
  stageName     String?
  // The word after JOIN that routes a new text straight to this creator's
  // plan, skipping the generic goal/experience interview (e.g. joinCode
  // "LARRY25" means texting "JOINLARRY25" joins Larry specifically). Stored
  // normalized (letters/digits only, uppercase) — see lib/join-code.ts —
  // since the SMS parser does exact-string matching on the trimmed,
  // uppercased message body.
  joinCode      String?  @unique
  photoUrl      String?
  bio           String?
  instagramUrl  String?
  youtubeUrl    String?
  tiktokUrl     String?
  introVideoUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── STEP 2: The workout program templates (seeded once, shared by all users) ─

// public = discoverable/followable by anyone (a creator's program for
// subscribers). personal = the creator's own individual plan — not
// followable by anyone but them, even with the direct /plan/{id} link (see
// app/api/follow-plan/route.ts). Only meaningful for creator-built plans;
// a regular athlete's own custom split has no followers to hide it from.
enum PlanVisibility {
  personal
  public
}

// A workout program (e.g. "Arnold Split"). One row shared by all users on that plan.
model WorkoutPlan {
  id              String         @id @default(uuid())
  name            String
  // Explicit goal this plan's rep-range math should use (e.g. "Build Muscle"),
  // set directly at creation time instead of inferred from the plan name — needed
  // for custom/creator-built plans, whose names won't follow the seeded naming
  // convention getUserGoalKey used to rely on. Null falls back to name-matching
  // for plans that predate this field.
  goal            String?
  // Who built this plan — null for the original seeded plans. Needed once plans
  // are publicly discoverable, so a shared plan can show "created by X".
  createdBy       User?          @relation("PlanCreator", fields: [createdByUserId], references: [id])
  createdByUserId String?
  // Defaults to public so every plan that predates this field (all seeded
  // plans, everyone's existing custom splits) keeps behaving exactly as
  // before — nothing existing suddenly becomes hidden or unfollowable.
  visibility      PlanVisibility @default(public)
  days            WorkoutDay[]
  userHistory     UserPlan[]
}

// One day inside a plan (e.g. Day 1: Chest and Back).
model WorkoutDay {
  id        String            @id @default(uuid())
  day       Int
  name      String
  muscles   String
  plan      WorkoutPlan       @relation(fields: [planId], references: [id])
  planId    String
  exercises PlannedExercise[]
  sessions  WorkoutSession[]
}

// controls how an exercise is logged and how targetReps is read:
//   weighted   (default) — weight x reps per set, e.g. "150x10 160x8"
//   cardio     — targetReps means recommended minutes, logged as a real minute count
//   bodyweight — reps per set, no weight, e.g. "15 12 10"
// Enforced at the database level — once users can add their own exercises (soon),
// this is the one thing that guarantees bad data can't sneak in outside the seed script.
// Adding a new type (crossfit, endurance, sprint...) means a small migration, on purpose.
enum ExerciseType {
  weighted
  cardio
  bodyweight
}

// One exercise inside a day (e.g. Bench Press — 4 sets x 10 reps). The blueprint.
model PlannedExercise {
  id           String        @id @default(uuid())
  name         String
  targetSets   Int
  targetReps   Int
  type         ExerciseType  @default(weighted)
  order        Int
  workoutDay   WorkoutDay    @relation(fields: [workoutDayId], references: [id])
  workoutDayId String
  // Soft-delete for REMOVE — never hard-deleted, since existing ExerciseLog rows
  // may already reference it and history should keep showing what really happened.
  // Forward-looking queries (today's/future workouts) filter to active: true;
  // history reads don't, so past sessions still show exercises later removed.
  active       Boolean       @default(true)
  logs         ExerciseLog[]
  // Optional — purely for pulling in gif/instructions/video content. Never
  // required, so a one-off custom exercise with no library match just shows
  // no enrichment instead of breaking anything.
  libraryExercise   ExerciseLibrary? @relation(fields: [libraryExerciseId], references: [id])
  libraryExerciseId String?
}

// The real, canonical source of "what exercises exist" — replaces the static
// body-parts.ts picker file. One row per distinct real-world exercise, shared
// across every plan/day that happens to use it, so enriching it once (a gif,
// real instructions, tutorial videos) shows up everywhere that exercise is
// used instead of needing to be re-entered per plan.
model ExerciseLibrary {
  id           String            @id @default(uuid())
  name         String            @unique
  // Optional, blank by default. `name` stays the stable lookup key plan files
  // and the seed script reference, so it should never change once other data
  // references it — displayName exists so an exercise can show under the name
  // people actually search for (e.g. "RDL") without breaking that link.
  displayName  String?
  bodyPart     String
  type         ExerciseType      @default(weighted)
  defaultSets  Int
  defaultReps  Int
  // All default to empty/null — content gets filled in over time via the
  // admin page, never required up front.
  gifUrl       String?
  instructions String[]          @default([])
  // Kept alongside English only — every other language in the bulk-imported
  // dataset gets dropped at import time, not stored.
  instructionsEs String[]        @default([])
  // Multiple videos on purpose (e.g. a male-demo and female-demo variant) —
  // no fixed meaning per index yet, just an ordered list of tutorial links.
  videoUrls    String[]          @default([])
  // Static reference photos, separate from gifUrl/videoUrls — same "just an
  // array" treatment, e.g. index 0 male / index 1 female later if wanted.
  imageUrls    String[]          @default([])
  // The specific muscle (e.g. "quadriceps", "glutes") from the bulk import —
  // used to decide bodyPart at import time, and kept for a possible future
  // narrower filter within a body part. Not used for navigation today.
  target       String?
  // Hand-curated "genuinely common" flag — most exercises default to false
  // since the bulk import added ~1,300 at once with no real usage data to
  // sort by. The picker shows featured first, everything else behind "See all".
  featured     Boolean           @default(false)
  plannedExercises PlannedExercise[]
  createdAt    DateTime          @default(now())
}

// ─── STEP 3: Connect users to plans and track their training ─────────────────

// Which plan the user is following and when. endDate null = currently active.
model UserPlan {
  id        String      @id @default(uuid())
  user      User        @relation(fields: [userId], references: [id])
  userId    String
  plan      WorkoutPlan @relation(fields: [planId], references: [id])
  planId    String
  startDate DateTime    @default(now())
  endDate   DateTime?
}

// Created each time a user trains. One row per gym visit.
model WorkoutSession {
  id           String        @id @default(uuid())
  date         DateTime      @default(now())
  // Null while a session is still open — set either automatically (every
  // exercise logged) or manually (the "Finish Workout" button), or by the app
  // auto-closing a session that's gone stale (see STALE_SESSION_HOURS in
  // lib/session-helpers.ts). This is the single source of truth for "which
  // session is currently in progress" — replaces guessing from whichever
  // session happens to have the latest date.
  finishedAt   DateTime?
  // True only for an extra/bonus session started after already completing
  // every planned day this week (see /api/today/bonus) — lets the app label
  // it "Bonus session" instead of "Day X of Y" without re-deriving that from
  // session counts.
  isBonus      Boolean       @default(false)
  user         User          @relation(fields: [userId], references: [id])
  userId       String
  workoutDay   WorkoutDay    @relation(fields: [workoutDayId], references: [id])
  workoutDayId String
  exercises    ExerciseLog[]
}

// The user's result on one exercise during a session. skipped = machine busy the
// whole session (see BUSY, which just reorders instead of ending up here).
model ExerciseLog {
  id                String           @id @default(uuid())
  order             Int
  skipped           Boolean          @default(false)
  session           WorkoutSession   @relation(fields: [sessionId], references: [id])
  sessionId         String
  // Null when this is an ad-hoc exercise (ADD) logged on the spot, not part of
  // the plan — customName holds its name instead. Never both null.
  plannedExercise   PlannedExercise? @relation(fields: [plannedExerciseId], references: [id])
  plannedExerciseId String?
  customName        String?
  // Only set alongside customName — type normally comes from plannedExercise,
  // but ad-hoc entries have no such row to read it from.
  type              ExerciseType?
  // Set once, at the moment a set beats the pre-existing best weight for this
  // exercise. Recorded here rather than recomputed later because an additive
  // edit (logging more sets onto an exercise already logged this session)
  // reuses this same row — comparing "this session's sets vs. other sessions"
  // after the fact would wrongly exclude the earlier sets in this same log
  // that the new ones actually need to beat.
  hitPR             Boolean          @default(false)
  sets              SetLog[]
}

// One individual set (e.g. 150lbs x 10 reps). Four rows = four sets done.
model SetLog {
  id            String      @id @default(uuid())
  setNumber     Int
  weight        Float
  reps          Int
  exerciseLog   ExerciseLog @relation(fields: [exerciseLogId], references: [id])
  exerciseLogId String
}

// ─── STEP 4: Remember where a real texting conversation left off ─────────────

// Real SMS has no browser session — this is what "state" and "context" persist to
// between one text and the next, keyed by phone number.
model SmsState {
  phone     String   @id
  state     String   @default("idle")
  context   Json     @default("{}")
  updatedAt DateTime @updatedAt
}
